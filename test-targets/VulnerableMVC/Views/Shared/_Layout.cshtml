<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Vulnerable Blog</title>
    <!-- VULNERABILITY (A05): No Content-Security-Policy header -->
    <!-- VULNERABILITY (A05): No X-Frame-Options header – clickjacking possible -->
    <style>
        body { font-family: sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; background: #f7f7f7; }
        nav { background: #333; padding: 1rem; border-radius: 8px; margin-bottom: 2rem; }
        nav a { color: white; text-decoration: none; margin-right: 1.5rem; }
        .card { background: white; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
        .danger { background: #fee; border-left: 4px solid #c00; }
        input, textarea { width: 100%; padding: 0.5rem; margin-bottom: 0.5rem; border: 1px solid #ddd; border-radius: 4px; }
        button { background: #2563eb; color: white; border: none; padding: 0.6rem 1.5rem; border-radius: 4px; cursor: pointer; }
    </style>
</head>
<body>
    <nav>
        <a href="/">Home</a>
        <a href="/Home/Search">Search</a>
        <a href="/Profile/Create">Create Profile</a>
    </nav>
    @RenderBody()
</body>
</html>
